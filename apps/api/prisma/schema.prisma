generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  QR_READY
  CONNECTED
}

enum Plan {
  FREE
  BASIC
  PRO
}

enum SubscriptionStatus {
  NONE
  PENDING
  ACTIVE
  PAST_DUE
  OVERDUE
  CANCELED
}

enum BillingPaymentMethod {
  FLEXIBLE
  CREDIT_CARD_RECURRING
}

enum WorkerNodeStatus {
  STARTING
  ACTIVE
  DRAINING
  STALE
  STOPPED
}

enum ReferralStatus {
  PENDING_SIGNUP
  PENDING_PAYMENT
  PENDING_WAITING_PERIOD
  NEEDS_REVIEW
  ELIGIBLE
  PAID
  REJECTED
}

model WorkerNode {
  id              String            @id @default(cuid())
  name            String            @unique
  status          WorkerNodeStatus  @default(STARTING)
  lastHeartbeatAt DateTime
  maxSessions     Int
  currentSessions Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        WhatsAppSession[]

  @@index([status, lastHeartbeatAt])
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  name                 String?
  cpfCnpj              String?
  cpfCnpjHash          String?
  referredByUserId     String?
  role                 String                @default("USER")
  plan                 Plan                  @default(FREE)
  subscriptionStatus   SubscriptionStatus    @default(NONE)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  subscriptions        Subscription[]
  billingSubscriptions BillingSubscription[]
  referralCode         ReferralCode?
  referralsMade        Referral[]            @relation("ReferralReferrer")
  referralReceived     Referral?             @relation("ReferralReferred")
  referredByUser       User?                 @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers        User[]                @relation("UserReferrals")
  adminAuditLogs        AdminAuditLog[]

  @@index([referredByUserId])
  @@index([cpfCnpjHash])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([adminUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  plan                   Plan
  status                 SubscriptionStatus @default(PENDING)
  provider               String?
  providerSubscriptionId String?
  checkoutUrl            String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([providerSubscriptionId])
}

model BillingSubscription {
  id                     String               @id @default(cuid())
  userId                 String
  plan                   Plan
  paymentMethod          BillingPaymentMethod @default(FLEXIBLE)
  provider               String               @default("asaas")
  providerCustomerId     String?
  providerSubscriptionId String?
  providerPaymentId      String?
  status                 SubscriptionStatus   @default(PENDING)
  checkoutUrl            String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  cancelAtPeriodEnd      Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([plan])
  @@index([providerCustomerId])
  @@index([providerSubscriptionId])
  @@index([providerPaymentId])
}

model BillingWebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([eventId])
  @@index([provider])
  @@index([eventType])
  @@index([processedAt])
}

model WhatsAppSession {
  id                   String                   @id @default(cuid())
  userId               String
  sessionId            String                   @unique
  status               WhatsAppConnectionStatus @default(DISCONNECTED)
  qrCode               String?
  qrCodeDataUrl        String?
  phoneNumber          String?
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  lastQrAt             DateTime?
  deletedAt            DateTime?
  workerId             String?
  lastHeartbeatAt      DateTime?
  workerLeaseExpiresAt DateTime?
  workerLeaseToken     String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  authStates           WhatsAppAuthState[]
  groups               WhatsAppGroup[]
  messages             WhatsAppMessage[]
  worker               WorkerNode?              @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([status])
  @@index([deletedAt])
  @@index([workerId])
  @@index([workerId, lastHeartbeatAt])
  @@index([workerLeaseExpiresAt])
}

model WhatsAppAuthState {
  id        String          @id @default(cuid())
  sessionId String
  type      String
  keyId     String
  value     Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   WhatsAppSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, type, keyId])
  @@index([sessionId])
  @@index([type])
}

model WhatsAppGroup {
  id               String          @id @default(cuid())
  sessionId        String
  groupJid         String
  name             String
  participantCount Int             @default(0)
  isCommunity      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  session          WhatsAppSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, groupJid])
  @@index([sessionId])
  @@index([groupJid])
}

model WhatsAppMessage {
  id           String          @id @default(cuid())
  sessionId    String
  groupJid     String
  senderJid    String?
  messageId    String          @unique
  messageType  String
  text         String?         @db.Text
  hasMedia     Boolean         @default(false)
  rawMessage   Json?
  links        Json?
  marketplaces Json?
  createdAt    DateTime        @default(now())
  session      WhatsAppSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
  @@index([groupJid])
  @@index([createdAt])
}

model AffiliateCredential {
  id          String   @id @default(cuid())
  userId      String
  marketplace String
  affiliateId String?
  apiKey      String?
  apiSecret   String?
  trackingId  String?
  storeSlug   String?
  metadata    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, marketplace])
  @@index([userId])
  @@index([marketplace])
}

model AffiliateGeneratorConfig {
  id           String   @id @default(cuid())
  marketplace  String   @unique
  method       String
  url          String
  headers      Json?
  bodyTemplate Json?
  responsePath String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model AffiliateLinkCache {
  id              String    @id @default(cuid())
  marketplace     String
  originalUrl     String    @db.Text
  resolvedUrl     String?   @db.Text
  originalUrlHash String    @unique
  affiliateUrl    String    @db.Text
  itemId          String?
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  expiresAt       DateTime?

  @@index([marketplace])
  @@index([expiresAt])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanPriceOverride {
  plan            String   @id
  priceCents      Int
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id                 String         @id @default(cuid())
  referrerUserId     String
  referredUserId     String         @unique
  status             ReferralStatus @default(PENDING_PAYMENT)
  rewardCents        Int            @default(3000)
  createdAt          DateTime       @default(now())
  paymentConfirmedAt DateTime?
  eligibleAt         DateTime?
  paidAt             DateTime?
  notes              String?        @db.Text
  antifraudReason    String?        @db.Text
  referrer           User           @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Restrict)
  referred           User           @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Restrict)

  @@index([referrerUserId])
  @@index([status])
  @@index([eligibleAt])
}

model MessageRoute {
  id                   String   @id @default(cuid())
  userId               String
  sessionId            String
  sourceGroupJid       String
  destinationGroupJid  String
  destinationInviteUrl String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, sessionId, sourceGroupJid, destinationGroupJid])
  @@index([userId])
  @@index([sessionId])
  @@index([sourceGroupJid])
  @@index([destinationGroupJid])
}

model ForwardedMessage {
  id                    String    @id @default(cuid())
  userId                String
  sessionId             String
  sourceMessageId       String
  sourceGroupJid        String
  destinationGroupJid   String
  originalText          String?   @db.Text
  rewrittenText         String    @db.Text
  status                String
  mode                  String?
  sentMessageType       String?
  mediaForwarded        Boolean   @default(false)
  sentProviderMessageId String?
  sentProviderRaw       Json?
  reason                String?
  error                 String?   @db.Text
  sentAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([sourceMessageId])
  @@index([destinationGroupJid])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
  @@index([userId, status, sentAt])
}

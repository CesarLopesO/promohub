generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  QR_READY
  CONNECTED
}

model WhatsAppSession {
  id             String                   @id @default(cuid())
  userId         String
  sessionId      String                   @unique
  status         WhatsAppConnectionStatus @default(DISCONNECTED)
  qrCode         String?
  qrCodeDataUrl  String?
  phoneNumber    String?
  connectedAt    DateTime?
  disconnectedAt DateTime?
  lastQrAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  authStates     WhatsAppAuthState[]
  groups         WhatsAppGroup[]

  @@index([userId])
  @@index([status])
}

model WhatsAppAuthState {
  id        String          @id @default(cuid())
  sessionId String
  type      String
  keyId     String
  value     Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   WhatsAppSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, type, keyId])
  @@index([sessionId])
  @@index([type])
}

model WhatsAppGroup {
  id               String          @id @default(cuid())
  sessionId        String
  groupJid         String
  name             String
  participantCount Int             @default(0)
  isCommunity      Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  session          WhatsAppSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@unique([sessionId, groupJid])
  @@index([sessionId])
  @@index([groupJid])
}

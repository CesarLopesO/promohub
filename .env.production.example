# Dominio publico. Use HTTPS em producao.
PEPPABOT_HTTP_PORT=80
PEPPABOT_WEB_URL=https://peppabot.example.com
PEPPABOT_NEXT_PUBLIC_API_URL=https://peppabot.example.com/api
PEPPABOT_CORS_ORIGIN=https://peppabot.com

# Banco interno do Compose. Use uma senha longa e exclusiva.
PEPPABOT_POSTGRES_USER=peppabot
PEPPABOT_POSTGRES_PASSWORD=change-me-before-production
PEPPABOT_POSTGRES_DB=peppabot
PEPPABOT_DATABASE_URL=postgresql://peppabot:change-me-before-production@postgres:5432/peppabot?schema=public
PEPPABOT_REDIS_URL=redis://redis:6379
PEPPABOT_RATE_LIMIT_REDIS_URL=redis://redis:6379
PEPPABOT_RATE_LIMIT_ENABLED=true
PEPPABOT_ADMIN_AUDIT_LOG_ENABLED=true

# Autenticacao.
PEPPABOT_JWT_SECRET=generate-a-long-random-secret
PEPPABOT_JWT_EXPIRES_IN=7d

# Deve ser uma chave base64 de 32 bytes. Depois de usada, nunca altere esta
# chave: credenciais ja criptografadas ficariam irrecuperaveis.
PEPPABOT_APP_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key

# Asaas de producao. Nunca reutilize credenciais do Sandbox.
PEPPABOT_ASAAS_API_KEY=
PEPPABOT_ASAAS_BASE_URL=https://api.asaas.com/v3
PEPPABOT_ASAAS_WALLET_ID=
PEPPABOT_ASAAS_WEBHOOK_TOKEN=generate-a-long-random-webhook-token

# Afiliados.
PEPPABOT_MERCADO_LIVRE_AFFILIATE_GENERATOR_URL=
PEPPABOT_MERCADO_LIVRE_MODE=real
PEPPABOT_MERCADO_LIVRE_LEGACY_FORWARD_ENABLED=false
PEPPABOT_MERCADO_LIVRE_CANDIDATE_MIN_SCORE=70
PEPPABOT_MERCADO_LIVRE_CANDIDATE_MIN_KEYWORDS=2
PEPPABOT_MERCADO_LIVRE_CANDIDATE_MIN_MARGIN=20

# Runtime WhatsApp embedded na API durante a Fase 1.
PEPPABOT_WHATSAPP_RUNTIME_MODE=embedded
PEPPABOT_WORKER_NAME=api-embedded-1
PEPPABOT_WORKER_MAX_SESSIONS=25
PEPPABOT_WORKER_HEARTBEAT_INTERVAL_MS=10000
PEPPABOT_WORKER_SESSION_LEASE_MS=30000
PEPPABOT_WORKER_STALE_AFTER_MS=45000
PEPPABOT_WHATSAPP_QUEUE_COMMANDS_ENABLED=false

# Worker dedicado da Fase 2. O servico usa o profile future-worker e permanece
# desligado no deploy padrao.
PEPPABOT_DEDICATED_WORKER_NAME=whatsapp-worker-1
PEPPABOT_DEDICATED_WORKER_MAX_SESSIONS=25

# Backup.
PEPPABOT_BACKUP_DIR=./backups/postgres
PEPPABOT_BACKUP_RETENTION_DAYS=14
